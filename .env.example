APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sargam
DB_USERNAME=root
DB_PASSWORD=

# --- LBSNAA authentication (required for production student/staff flows) ---
# Copy values from your secure store (previously hard-coded in LoginController).
AUTH_STUDENT_LOGIN_SECRET=
# Optional staff emergency bypass; leave empty to force LDAP for all staff
AUTH_STAFF_LDAP_BYPASS_SECRET=
# Comma-separated request hosts that skip password check (dev/staging only).
# Production: set to empty string AUTH_PASSWORDLESS_HOSTS=
AUTH_PASSWORDLESS_HOSTS=localhost,127.0.0.1,dev.local

# Word of the Day rotation anchor (optional, Y-m-d)
WORD_OF_DAY_ANCHOR_DATE=1970-01-01
